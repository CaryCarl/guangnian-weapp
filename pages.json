{
	"easycom": {
		"^u-(.*)": "uview-ui/components/u-$1/u-$1.vue"
	},
	"pages": [
		{
			"path": "pages/resource/resource",
			"style": {
				"navigationBarTitleText": "免费资源",
				"enablePullDownRefresh": false,
				"onReachBottomDistance": 150,
				"navigationStyle": "custom"
			}
		},
		{
			"path": "pages/index/index",
			"style": {
				"navigationBarTitleText": "图库",
				"enablePullDownRefresh": false,
				"onReachBottomDistance": 150,
				"navigationStyle": "custom",
				"renderer": "skyline",
				"componentFramework": "glass-easel",
				"disableScroll": true
			}
		},
		{
			"path": "pages/type/type",
			"style": {
				"navigationBarTitleText": "分类",
				"enablePullDownRefresh": false,
				"onReachBottomDistance": 150,
				"navigationStyle": "custom"
			}
		},
		{
			"path": "pages/my/my",
			"style": {
				"navigationBarTitleText": "我的",
				"onReachBottomDistance": 60,
				"enablePullDownRefresh": false
			}
		},
		{
			"path": "pages/imgDetails/imgDetails",
			"style": {
				"navigationBarTitleText": "",
				"navigationStyle": "custom",
				"renderer": "skyline",
				"componentFramework": "glass-easel",
				"disableScroll": true
			}
		},
		{
			"path": "pages/collect/img-collect",
			"style": {
				"navigationBarTitleText": "壁纸收藏"
			}
		},
		{
			"path": "pages/collect/resource-collect",
			"style": {
				"navigationBarTitleText": "资源列表"
			}
		},
		{
			"path": "pages/my/about/about",
			"style": {
				"navigationBarTitleText": "更新日志"
			}
		},
		{
			"path": "pages/detail/detail",
			"style": {
				"navigationBarTitleText": "",
				"renderer": "skyline",
				"componentFramework": "glass-easel",
				"disableScroll": true
			}
		},
		{
			"path": "pages/resource/details/details",
			"style": {
				"navigationBarTitleText": "",
				"navigationStyle": "custom",
				"renderer": "skyline",
				"componentFramework": "glass-easel",
				"disableScroll": true
			}
		}
	],
	"globalStyle": {
		"navigationBarTextStyle": "black",
		"navigationBarTitleText": "",
		"navigationBarBackgroundColor": "#ffffff",
		"backgroundColor": "#ffffff"
	},
	"tabBar": {
		"borderStyle": "white",
		"color": "#57595c",
		"height": "80rpx",
		"fontSize": "22px",
		"selectedColor": "#f05b47",
		"backgroundColor": "#ffffff",
		"custom": false,
		"list": [
			{
				"pagePath": "pages/resource/resource",
				"text": "资源",
				"selectedIconPath": "/static/tabbar/home-active.png",
				"iconPath": "/static/tabbar/home.png"
			},
			{
				"pagePath": "pages/index/index",
				"text": "图库",
				"selectedIconPath": "/static/tabbar/faxian-active.png",
				"iconPath": "/static/tabbar/faxian.png"
			},
			{
				"pagePath": "pages/type/type",
				"text": "分类",
				"selectedIconPath": "/static/tabbar/guige-active.png",
				"iconPath": "/static/tabbar/guige.png"
			},
			{
				"pagePath": "pages/my/my",
				"text": "我的",
				"selectedIconPath": "/static/tabbar/my-active.png",
				"iconPath": "/static/tabbar/my.png"
			}
		]
	}
}